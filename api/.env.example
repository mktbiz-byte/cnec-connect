# Node env
NODE_ENV=development
PORT=4000

# Database — Railway에서 PostgreSQL 플러그인 추가 시 자동 제공
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cnec_connect

# JWT — `openssl rand -hex 32`로 생성
JWT_SECRET=change-me-in-production-access
JWT_REFRESH_SECRET=change-me-in-production-refresh

# Cookie
COOKIE_DOMAIN=
COOKIE_SECURE=false

# CORS — 프론트 배포 도메인. 콤마로 구분하여 여러 개
CORS_ORIGIN=http://localhost:5173

# Payments — stripe | mock
PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
